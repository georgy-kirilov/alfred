# Default: normalize text files and use LF in the working tree
* text=auto eol=lf

# .NET / repo text files
*.cs            text eol=lf
*.csx           text eol=lf
*.fs            text eol=lf
*.fsx           text eol=lf
*.vb            text eol=lf

*.csproj        text eol=lf
*.fsproj        text eol=lf
*.vbproj        text eol=lf
*.props         text eol=lf
*.targets       text eol=lf
*.sln           text eol=lf
*.slnx          text eol=lf

*.json          text eol=lf
*.xml           text eol=lf
*.config        text eol=lf
*.xaml          text eol=lf
*.resx          text eol=lf

*.yml           text eol=lf
*.yaml          text eol=lf
*.toml          text eol=lf

*.editorconfig  text eol=lf
*.gitattributes text eol=lf
*.gitignore     text eol=lf
*.dockerignore  text eol=lf

*.md            text eol=lf
*.txt           text eol=lf
*.csv           text eol=lf

*.sh            text eol=lf

# Windows scripts
*.bat           text eol=crlf
*.cmd           text eol=crlf
*.ps1           text eol=crlf
*.psm1          text eol=crlf
*.psd1          text eol=crlf

# Binary files
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.bmp           binary
*.ico           binary
*.webp          binary
*.pdf           binary
*.zip           binary
*.gz            binary
*.7z            binary
*.dll           binary
*.exe           binary
*.so            binary
*.dylib         binary
*.pdb           binary
*.snk           binary
*.nupkg         binary
*.woff          binary
*.woff2         binary
